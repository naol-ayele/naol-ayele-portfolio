# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of origins allowed to call this API (your deployed frontend URL)
ALLOWED_ORIGINS=http://localhost:5500,https://your-portfolio-domain.com

# Simple admin key — required in the x-api-key header for protected routes
# (creating blog posts, reading analytics summary). Make this long and random.
ADMIN_API_KEY=change-me-to-a-long-random-string

# --- Email (optional, for the contact form notification) ---
# If left blank, contact messages are still saved to the database,
# they just won't trigger an email notification.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-app-password
CONTACT_TO_EMAIL=naolayele85@gmail.com
